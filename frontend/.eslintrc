{
  "extends": [
    "plugin:vue/vue3-essential",
    "plugin:vue/vue3-recommended",
    "plugin:vue/vue3-strongly-recommended",
    "eslint:recommended",
    "prettier",
    "@vue/typescript/recommended"
  ],
  "rules": {
    // override/add rules settings here, such as:
    "vue/no-unused-vars": "error",
    "semi": "error",
    "comma-dangle": "error"
  }
}